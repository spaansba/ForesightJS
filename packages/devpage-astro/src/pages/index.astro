---
import { ForesightLink } from "@foresightjs/astro/components"
import Layout from "../layouts/Layout.astro"

const card =
  "block border border-gray-300 bg-white p-6 space-y-1 " +
  "data-predicted:border-emerald-600 data-predicted:bg-emerald-50"
---

<Layout title="Foresight prefetch strategies">
  <p class="text-sm text-gray-700 leading-relaxed max-w-2xl">
    Every unattributed link on this page is registered with ForesightJS (<code
      class="font-mono text-xs">prefetchAll: true, defaultStrategy: "foresight"</code
    >). Open the devtools overlay and the network tab, then move the mouse toward a link: predicted
    links turn green and the page is prefetched before the cursor arrives.
  </p>

  <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
    <a class={card} href="/about/">
      <span class="text-sm font-medium text-gray-900">Default link</span>
      <span class="block text-xs text-gray-500">foresight via defaultStrategy</span>
    </a>

    <a
      class={card}
      href="/strategies/"
      data-astro-prefetch="foresight"
      data-foresight-hit-slop="60 10 5 0"
    >
      <span class="text-sm font-medium text-gray-900">Explicit foresight</span>
      <span class="block text-xs text-gray-500">hitSlop 40 via data attribute</span>
    </a>

    <ForesightLink class={card} href="/mass/" hitSlop={60} name="component-link">
      <span class="text-sm font-medium text-gray-900">ForesightLink</span>
      <span class="block text-xs text-gray-500">component, hitSlop 60</span>
    </ForesightLink>

    <a class={card} href="/strategies/" data-astro-prefetch="hover">
      <span class="text-sm font-medium text-gray-900">Astro hover</span>
      <span class="block text-xs text-gray-500">native strategy, untouched</span>
    </a>

    <a class={card} href="/mass/" data-astro-prefetch="false">
      <span class="text-sm font-medium text-gray-900">Opted out</span>
      <span class="block text-xs text-gray-500">never prefetched</span>
    </a>

    <a class={card} href="/about/" data-foresight-enabled="false">
      <span class="text-sm font-medium text-gray-900">Disabled</span>
      <span class="block text-xs text-gray-500">registered but inactive</span>
    </a>
  </div>

  <p class="text-xs text-gray-400 font-mono">
    nav links get hitSlop 30 from rules, everything else inherits hitSlop 10 from linkDefaults
  </p>
</Layout>
