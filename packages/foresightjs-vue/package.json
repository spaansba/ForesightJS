{
  "name": "@foresightjs/vue",
  "version": "1.0.0",
  "description": "Vue composables for ForesightJS - register elements with the ForesightManager from Vue components.",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsdown --sourcemap",
    "build:prod": "tsdown",
    "dev": "tsdown --sourcemap --watch",
    "lint": "eslint . --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "prepublishOnly": "pnpm test:run && pnpm build:prod"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "homepage": "https://foresightjs.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spaansba/ForesightJS",
    "directory": "packages/foresightjs-vue"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "vue",
    "foresight",
    "js.foresight",
    "foresightjs",
    "vue-composable",
    "prefetch",
    "interaction-prediction",
    "mouse-trajectory",
    "useForesight"
  ],
  "author": "Bart Spaans",
  "license": "MIT",
  "llms": "https://foresightjs.com/llms.txt",
  "llmsFull": "https://foresightjs.com/llms-full.txt",
  "peerDependencies": {
    "js.foresight": "^4.2.2",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "js.foresight": "workspace:*",
    "jsdom": "^29.0.1",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "unplugin-vue": "^7.2.0",
    "vitest": "^4.1.2",
    "vue": "^3.5.17",
    "vue-tsc": "^3.2.6"
  }
}
