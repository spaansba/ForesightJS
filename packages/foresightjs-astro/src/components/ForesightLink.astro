---
import type { HTMLAttributes } from "astro/types"
import { serializeHitSlop } from "../hitSlop"
import { FORESIGHT_STRATEGY, type ForesightLinkOptions } from "../types"

interface Props
  extends ForesightLinkOptions,
    Omit<HTMLAttributes<"a">, "data-astro-prefetch" | keyof ForesightLinkOptions> {}

const { hitSlop, name, reactivateAfter, enabled, ...rest } = Astro.props
---

<a
  {...rest}
  data-astro-prefetch={FORESIGHT_STRATEGY}
  data-foresight-hit-slop={serializeHitSlop(hitSlop)}
  data-foresight-name={name}
  data-foresight-reactivate-after={reactivateAfter}
  data-foresight-enabled={enabled === false ? "false" : undefined}><slot /></a>
